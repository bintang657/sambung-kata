local function FindQuestionLabel(parent)
    local result = nil
    local candidates = {}

    pcall(function()
        for _, descendant in ipairs(parent:GetDescendants()) do
            if (descendant:IsA("TextLabel") or descendant:IsA("TextButton")) 
                and descendant.Visible ~= false then
                local name = descendant.Name:lower()
                local text = descendant.Text or ""

                -- Prioritaskan label dengan nama terkait pertanyaan/kata
                if name:find("question") or name:find("word") or name:find("kata")
                    or name:find("soal") or name:find("current") or name:find("display")
                    or name:find("prompt") or name:find("last") or name:find("sambung") then
                    table.insert(candidates, {priority = 1, instance = descendant})
                elseif text ~= "" and #text > 1 and #text < 50 then
                    -- Label dengan teks yang masuk akal (bukan terlalu pendek/panjang)
                    table.insert(candidates, {priority = 2, instance = descendant})
                end
            end
        end
    end)

    -- Urutkan berdasarkan prioritas
    table.sort(candidates, function(a, b) return a.priority < b.priority end)

    if #candidates > 0 then
        result = candidates[1].instance
    end

    return result
end

--- Mencari tombol join/play di game
--- @param parent Instance - Parent untuk mulai pencarian
--- @return Instance|nil - Button yang ditemukan
local function FindJoinButton(parent)
    local result = nil
    pcall(function()
        for _, descendant in ipairs(parent:GetDescendants()) do
            if descendant:IsA("TextButton") or descendant:IsA("ImageButton") then
                local name = descendant.Name:lower()
                local text = ""
                if descendant:IsA("TextButton") then
                    text = (descendant.Text or ""):lower()
                end

                if name:find("join") or name:find("play") or name:find("mulai")
                    or name:find("start") or name:find("main") or name:find("masuk")
                    or text:find("join") or text:find("play") or text:find("mulai")
                    or text:find("main") or text:find("masuk") then
                    result = descendant
                    return
                end
            end
        end
    end)
    return result
end

