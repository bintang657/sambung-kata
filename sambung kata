--- Menghasilkan delay acak antara min dan max detik
--- @return number - Waktu delay acak
local function GetRandomDelay()
    local minDelay = _G.KimjongDelay[1] or 2
    local maxDelay = _G.KimjongDelay[2] or 5
    -- Pastikan min tidak lebih besar dari max
    if minDelay > maxDelay then
        minDelay, maxDelay = maxDelay, minDelay
    end
    return minDelay + math.random() * (maxDelay - minDelay)
end

--- Mendapatkan huruf terakhir dari sebuah kata (case-insensitive, uppercase)
--- @param kata string - Kata yang akan diambil huruf terakhirnya
--- @return string - Huruf terakhir dalam uppercase
local function GetHurufTerakhir(kata)
    if not kata or kata == "" then return "" end
    -- Bersihkan spasi dan karakter khusus di akhir
    kata = kata:gsub("[%s%p]+$", "")
    if kata == "" then return "" end
    return kata:sub(-1, -1):upper()
end

--- Mencari kata dari database yang berawalan huruf tertentu
--- Menghindari kata yang sudah dipakai di ronde ini
--- @param huruf string - Huruf awal yang dicari
--- @return string|nil - Kata yang ditemukan, atau nil jika tidak ada
local function CariKata(huruf)
    huruf = huruf:upper()

    -- Cek apakah ada kata di database untuk huruf ini
    if not KamusIndonesia[huruf] or #KamusIndonesia[huruf] == 0 then
        warn("[KimJong] Tidak ada kata untuk huruf: " .. huruf)
        return nil
    end

    -- Kumpulkan kata-kata yang belum dipakai
    local availableWords = {}
    for _, kata in ipairs(KamusIndonesia[huruf]) do
        if not UsedThisRound[kata:lower()] then
            table.insert(availableWords, kata)
        end
    end

    -- Jika semua kata sudah dipakai, reset dan coba lagi
    if #availableWords == 0 then
        warn("[KimJong] Semua kata huruf " .. huruf .. " sudah terpakai, mereset...")
        -- Reset hanya kata-kata dengan huruf ini
        for _, kata in ipairs(KamusIndonesia[huruf]) do
            UsedThisRound[kata:lower()] = nil
        end
        availableWords = KamusIndonesia[huruf]
    end

    -- Pilih kata secara random dari yang tersedia
    local index = math.random(1, #availableWords)
    local selectedWord = availableWords[index]

    -- Tandai kata sebagai sudah dipakai
    UsedThisRound[selectedWord:lower()] = true

    return selectedWord
end

--- Menambahkan kata ke log dan memperbarui UI
--- @param kata string - Kata yang digunakan
--- @param hurufDari string - Huruf yang diminta (huruf terakhir kata sebelumnya)
local function LogKata(kata, hurufDari)
    local timestamp = os.date("%H:%M:%S")
    local entry = string.format("[%s] %s → %s", timestamp, hurufDari, kata)
    table.insert(UsedWordsLog, entry)

    -- Batasi log agar tidak terlalu banyak (simpan 50 terakhir)
    if #UsedWordsLog > 50 then
        table.remove(UsedWordsLog, 1)
    end

    -- Update UI log jika tersedia
    pcall(function()
        if _G._KimjongLogLabel then
            -- Tampilkan 15 entry terakhir
            local displayLog = ""
            local startIdx = math.max(1, #UsedWordsLog - 14)
            for i = #UsedWordsLog, startIdx, -1 do
                displayLog = displayLog .. UsedWordsLog[i] .. "\n"
            end
            _G._KimjongLogLabel:Set(displayLog)
        end
    end)

    -- Update statistik
    pcall(function()
        if _G._KimjongStatsLabel then
            local totalDB = 0
            for _, words in pairs(KamusIndonesia) do
                totalDB = totalDB + #words
            end
            _G._KimjongStatsLabel:Set(
                "Kata terpakai: " .. #UsedWordsLog .. " | Database: " .. totalDB .. " kata"
            )
        end
    end)
end

--- Simulasi mengetik di TextBox game
--- Mengirimkan teks karakter per karakter untuk terlihat natural
--- @param textbox Instance - TextBox target di game
--- @param text string - Teks yang akan diketik
local function SimulasiKetik(textbox, text)
    pcall(function()
        if textbox and textbox:IsA("TextBox") then
            -- Fokus ke textbox
            textbox:CaptureFocus()
            task.wait(0.3)

            -- Ketik karakter satu per satu untuk efek natural
            textbox.Text = ""
            for i = 1, #text do
                textbox.Text = text:sub(1, i)
                -- Delay kecil antar karakter (50-150ms)
                task.wait(0.05 + math.random() * 0.1)
            end

            task.wait(0.2)

            -- Simulasi tekan Enter untuk mengirim
            -- Beberapa game menggunakan FocusLost event
            textbox:ReleaseFocus(true) -- true = enterPressed
        end
    end)
end

--- Mencari TextBox input di PlayerGui secara rekursif
--- @param parent Instance - Parent untuk mulai pencarian
--- @return Instance|nil - TextBox yang ditemukan
local function FindInputTextBox(parent)
    local result = nil
    pcall(function()
        -- Cari di semua descendants
        for _, descendant in ipairs(parent:GetDescendants()) do
            if descendant:IsA("TextBox") and descendant.Visible ~= false then
                -- Cari TextBox yang kemungkinan digunakan untuk input jawaban
                local name = descendant.Name:lower()
                if name:find("input") or name:find("answer") or name:find("text")
                    or name:find("chat") or name:find("type") or name:find("jawab")
                    or name:find("kata") or name:find("box") then
                    result = descendant
                    return
                end
            end
        end

        -- Jika tidak ditemukan dengan nama spesifik, ambil TextBox pertama yang visible
        if not result then
            for _, descendant in ipairs(parent:GetDescendants()) do
                if descendant:IsA("TextBox") and descendant.Visible ~= false then
                    -- Pastikan TextBox ini bisa berinteraksi
                    local parentGui = descendant:FindFirstAncestorOfClass("ScreenGui")
                    if parentGui and parentGui.Enabled ~= false then
                        result = descendant
                        return
                    end
                end
            end
        end
    end)
    return result
end

