--- Loop yang memonitor dan otomatis bergabung ke ronde baru
local function AutoJoinLoop()
    while _G.KimjongEnabled do
        pcall(function()
            if _G.KimjongAutoJoin then
                -- Cari tombol join di PlayerGui
                local joinButton = FindJoinButton(PlayerGui)

                if joinButton and joinButton.Visible ~= false then
                    -- Cek apakah tombol bisa diklik
                    local parentGui = joinButton:FindFirstAncestorOfClass("ScreenGui")
                    if parentGui and parentGui.Enabled ~= false then
                        print("[KimJong] 🔄 Tombol join ditemukan, bergabung...")

                        -- Delay singkat sebelum join
                        task.wait(1 + math.random() * 2)

                        -- Klik tombol
                        pcall(function()
                            -- Gunakan fireclick jika executor mendukung
                            if fireclickdetector then
                                fireclickdetector(joinButton)
                            elseif firesignal then
                                firesignal(joinButton.Activated)
                                firesignal(joinButton.MouseButton1Click)
                            else
                                -- Fallback: simulasi mouse click
                                local pos = joinButton.AbsolutePosition
                                local size = joinButton.AbsoluteSize
                                local centerX = pos.X + size.X / 2
                                local centerY = pos.Y + size.Y / 2

                                pcall(function()
                                    VirtualInputManager:SendMouseButtonEvent(
                                        centerX, centerY, 0, true, game, 1
                                    )
                                    task.wait(0.05)
                                    VirtualInputManager:SendMouseButtonEvent(
                                        centerX, centerY, 0, false, game, 1
                                    )
                                end)
                            end
                        end)

                        -- Reset kata yang sudah dipakai untuk ronde baru
                        UsedThisRound = {}

                        pcall(function()
                            if Rayfield then
                                Rayfield:Notify({
                                    Title = "Auto Join",
                                    Content = "🔄 Bergabung ke ronde baru!",
                                    Duration = 3
                                })
                            end
                        end)

                        -- Tunggu sebelum cek lagi (hindari spam klik)
                        task.wait(5)
                    end
                end
            end
        end)

        -- Cek setiap 2 detik
        task.wait(2)
    end

    print("[KimJong] Auto Join loop dihentikan.")
end

