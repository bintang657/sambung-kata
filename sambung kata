-- ============================================================

--- Loop utama yang memonitor perubahan UI game
--- Mendeteksi kata yang ditampilkan dan memberikan jawaban otomatis
local function MainAutoAnswerLoop()
    local lastDetectedWord = "" -- Simpan kata terakhir agar tidak memproses ulang

    while _G.KimjongEnabled do
        pcall(function()
            if _G.KimjongAutoAnswer then
                -- Cari label pertanyaan di PlayerGui
                local questionLabel = FindQuestionLabel(PlayerGui)

                if questionLabel then
                    local currentWord = questionLabel.Text or ""
                    currentWord = currentWord:gsub("^%s+", ""):gsub("%s+$", "")

                    -- Hanya proses jika kata berubah (bukan kata yang sama)
                    if currentWord ~= "" and currentWord ~= lastDetectedWord and #currentWord > 1 then
                        lastDetectedWord = currentWord

                        local hurufTerakhir = GetHurufTerakhir(currentWord)

                        if hurufTerakhir ~= "" and hurufTerakhir:match("[A-Z]") then
                            local jawaban = CariKata(hurufTerakhir)

                            if jawaban then
                                -- Delay random agar terlihat natural
                                local delay = GetRandomDelay()

                                print("[KimJong] UI Detected: '" .. currentWord .. 
                                    "' → Huruf: " .. hurufTerakhir .. 
                                    " → Jawaban: " .. jawaban ..
                                    " (delay: " .. string.format("%.1f", delay) .. "s)")

                                -- Notifikasi di UI
                                pcall(function()
                                    if Rayfield then
                                        Rayfield:Notify({
                                            Title = "🎯 Kata Terdeteksi",
                                            Content = currentWord .. " → " .. jawaban,
                                            Duration = 3
                                        })
                                    end
                                end)

                                task.wait(delay)

                                -- Verifikasi masih enabled setelah delay
                                if _G.KimjongEnabled and _G.KimjongAutoAnswer then
                                    -- Cari TextBox input dan kirim jawaban
                                    local inputBox = FindInputTextBox(PlayerGui)

                                    if inputBox then
                                        SimulasiKetik(inputBox, jawaban)
                                        LogKata(jawaban, hurufTerakhir)
                                        print("[KimJong] ✅ Jawaban terkirim: " .. jawaban)
                                    else
                                        -- Alternatif: coba kirim via remote
                                        pcall(function()
                                            for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
                                                if remote:IsA("RemoteEvent") then
                                                    local rName = remote.Name:lower()
                                                    if rName:find("answer") or rName:find("submit")
                                                        or rName:find("send") or rName:find("chat")
                                                        or rName:find("kata") or rName:find("jawab") then
                                                        remote:FireServer(jawaban)
                                                        LogKata(jawaban, hurufTerakhir)
                                                        print("[KimJong] ✅ Jawaban dikirim via Remote: " .. jawaban)
                                                        break
                                                    end
                                                end
                                            end
                                        end)
                                    end
                                end
                            else
                                warn("[KimJong] ⚠️ Tidak ada kata untuk huruf: " .. hurufTerakhir)
                            end
                        end
                    end
                end
            end
        end)

        -- Interval polling (0.5 detik untuk responsif tapi tidak terlalu berat)
        task.wait(0.5)
    end

    print("[KimJong] Main loop dihentikan.")
end

