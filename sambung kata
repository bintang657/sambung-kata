--- Memonitor RemoteEvent untuk mendeteksi kata dari game
--- Beberapa game Sambung Kata menggunakan RemoteEvent untuk broadcast kata
local function SetupRemoteListener()
    pcall(function()
        -- Cari semua RemoteEvent di ReplicatedStorage
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") then
                local remoteName = remote.Name:lower()

                -- Filter remote yang mungkin terkait game sambung kata
                if remoteName:find("word") or remoteName:find("kata")
                    or remoteName:find("answer") or remoteName:find("sambung")
                    or remoteName:find("game") or remoteName:find("round")
                    or remoteName:find("question") or remoteName:find("chat") then

                    pcall(function()
                        remote.OnClientEvent:Connect(function(...)
                            if not _G.KimjongEnabled or not _G.KimjongAutoAnswer then
                                return
                            end

                            local args = {...}

                            -- Coba proses setiap argumen sebagai kata
                            for _, arg in ipairs(args) do
                                if type(arg) == "string" and #arg > 1 then
                                    local hurufTerakhir = GetHurufTerakhir(arg)

                                    if hurufTerakhir ~= "" then
                                        local jawaban = CariKata(hurufTerakhir)

                                        if jawaban then
                                            -- Delay random sebelum menjawab
                                            local delay = GetRandomDelay()
                                            print("[KimJong] Kata terdeteksi via Remote: '" .. arg .. 
                                                "' → Huruf: " .. hurufTerakhir .. 
                                                " → Jawaban: " .. jawaban ..
                                                " (delay: " .. string.format("%.1f", delay) .. "s)")

                                            task.wait(delay)

                                            -- Cari TextBox dan kirim jawaban
                                            local inputBox = FindInputTextBox(PlayerGui)
                                            if inputBox then
                                                SimulasiKetik(inputBox, jawaban)
                                                LogKata(jawaban, hurufTerakhir)
                                            end
                                        end
                                    end
                                end
                            end
                        end)
                    end)
                end
            end
        end

        print("[KimJong] Remote listener berhasil disetup.")
    end)
end

